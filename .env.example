# ── vimigo TCVR Revenue OS — backend environment ─────────────────────────────
# Copy this file to `.env` and fill in your key. The .env file is git-ignored
# and is ONLY read by the backend (server-side). The browser never sees the key.

# Anthropic API key for the AI features (website scan, product categorization,
# forecast narrative, vimiGoal draft). Leave blank to run the app fully on the
# offline rule-based engine — AI panels degrade gracefully.
ANTHROPIC_API_KEY=

# Backend port (Vite dev server proxies /api → this port).
PORT=3001

# Models. opus = best voice for narratives; sonnet = fast/cheap for structured tasks.
MODEL_SMART=claude-opus-4-8
MODEL_FAST=claude-sonnet-4-6

# Timeout (ms) for fetching a customer's website during the AI scan.
SCAN_FETCH_TIMEOUT_MS=8000
